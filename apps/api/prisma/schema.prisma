generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String?  @unique
  password     String
  color_custom String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
